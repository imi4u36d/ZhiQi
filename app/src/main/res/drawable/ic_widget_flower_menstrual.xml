<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center_horizontal|top">
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="26dp" />
            <solid android:color="#FFF2BBCB" />
        </shape>
    </item>

    <item android:gravity="center_vertical|left">
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="26dp" />
            <solid android:color="#FFF5CBD6" />
        </shape>
    </item>

    <item android:gravity="center_vertical|right">
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="26dp" />
            <solid android:color="#FFF5CBD6" />
        </shape>
    </item>

    <item android:gravity="center_horizontal|bottom">
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="26dp" />
            <solid android:color="#FFF2BBCB" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size
                android:width="16dp"
                android:height="16dp" />
            <solid android:color="#FFD88FA7" />
        </shape>
    </item>
</layer-list>
