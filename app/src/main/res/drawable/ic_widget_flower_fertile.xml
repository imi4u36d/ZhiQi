<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center_horizontal|top">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="24dp" />
            <solid android:color="#FFE9D7EE" />
        </shape>
    </item>

    <item
        android:gravity="left|top"
        android:left="10dp"
        android:top="6dp">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="24dp" />
            <solid android:color="#FFF0E4F4" />
        </shape>
    </item>

    <item
        android:gravity="right|top"
        android:right="10dp"
        android:top="6dp">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="24dp" />
            <solid android:color="#FFF0E4F4" />
        </shape>
    </item>

    <item
        android:gravity="left|bottom"
        android:left="10dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="24dp" />
            <solid android:color="#FFF7EDF9" />
        </shape>
    </item>

    <item
        android:gravity="right|bottom"
        android:right="10dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="24dp" />
            <solid android:color="#FFF7EDF9" />
        </shape>
    </item>

    <item android:gravity="center_horizontal|bottom">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="24dp" />
            <solid android:color="#FFE9D7EE" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="14dp" />
            <solid android:color="#FFB89CCB" />
        </shape>
    </item>
</layer-list>
