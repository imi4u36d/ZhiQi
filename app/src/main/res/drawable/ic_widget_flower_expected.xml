<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center_horizontal|bottom">
        <shape android:shape="rectangle">
            <size
                android:width="8dp"
                android:height="20dp" />
            <corners android:radius="6dp" />
            <solid android:color="#FFA9C39F" />
        </shape>
    </item>

    <item android:gravity="center_horizontal|top">
        <shape android:shape="oval">
            <size
                android:width="18dp"
                android:height="24dp" />
            <solid android:color="#FFF0BECF" />
        </shape>
    </item>

    <item
        android:gravity="left|top"
        android:left="12dp"
        android:top="10dp">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="20dp" />
            <solid android:color="#FFF7D7E1" />
        </shape>
    </item>

    <item
        android:gravity="right|top"
        android:right="12dp"
        android:top="10dp">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="20dp" />
            <solid android:color="#FFF7D7E1" />
        </shape>
    </item>

    <item android:gravity="center">
        <shape android:shape="oval">
            <size
                android:width="14dp"
                android:height="14dp" />
            <solid android:color="#FFD88FA7" />
        </shape>
    </item>
</layer-list>
